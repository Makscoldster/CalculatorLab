<Window x:Class="CalculatorLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        KeyDown="Window_KeyDown"
        Title="Калькулятор Lab2" Height="900" Width="600" MinHeight="500" MinWidth="300">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Expression -->
        <TextBlock x:Name="ExpressionText"
                   Grid.Row="0" Grid.ColumnSpan="4"
                   FontSize="28" FontWeight="Bold" TextAlignment="Right"
                   VerticalAlignment="Center"
                   Text="" Foreground="Gray" Margin="0,0,5,10"/>

        <!-- Display -->
        <TextBox x:Name="Display"
                 Grid.Row="1" Grid.ColumnSpan="4"
                 FontSize="48" FontWeight="Bold" TextAlignment="Right"
                 Text="0" IsReadOnly="True" VerticalContentAlignment="Center"
                 Margin="0,0,5,10"/>

        <!-- Undo / Redo -->
        <Button x:Name="BtnUndo"
                Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Content="&#x21A9; Undo" Click="UndoButton_Click"
                Margin="2" FontSize="28"
                Background="LightYellow" IsEnabled="False"/>
        <Button x:Name="BtnRedo"
                Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                Content="&#x21AA; Redo" Click="RedoButton_Click"
                Margin="2" FontSize="28"
                Background="LightYellow" IsEnabled="False"/>

        <!-- 7 8 9 ÷ -->
        <Button Grid.Row="3" Grid.Column="0" Content="7"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="3" Grid.Column="1" Content="8"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="3" Grid.Column="2" Content="9"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="3" Grid.Column="3" Content="&#247;" Click="OperatorButton_Click"  Margin="2" FontSize="48"/>

        <!-- 4 5 6 × -->
        <Button Grid.Row="4" Grid.Column="0" Content="4"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="4" Grid.Column="1" Content="5"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="4" Grid.Column="2" Content="6"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="4" Grid.Column="3" Content="&#215;" Click="OperatorButton_Click"  Margin="2" FontSize="48"/>

        <!-- 1 2 3 − -->
        <Button Grid.Row="5" Grid.Column="0" Content="1"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="5" Grid.Column="1" Content="2"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="5" Grid.Column="2" Content="3"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="5" Grid.Column="3" Content="&#8722;" Click="OperatorButton_Click" Margin="2" FontSize="48"/>

        <!-- +/- 0 . + -->
        <Button Grid.Row="6" Grid.Column="0" Content="+/-" Click="ToggleSignButton_Click"   Margin="2" FontSize="36"/>
        <Button Grid.Row="6" Grid.Column="1" Content="0"   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="6" Grid.Column="2" Content="."   Click="NumberButton_Click"       Margin="2" FontSize="48"/>
        <Button Grid.Row="6" Grid.Column="3" Content="+"   Click="OperatorButton_Click"     Margin="2" FontSize="48"/>

        <!-- CE  C  ⌫  = -->
        <Button Grid.Row="7" Grid.Column="0" Content="CE"
                Click="CEButton_Click" Margin="2"
                Background="LightCoral" FontSize="48"
                ToolTip="Undo — повернути останню дію"/>
        <Button Grid.Row="7" Grid.Column="1" Content="C"
                Click="CButton_Click"  Margin="2"
                Background="LightCoral" FontSize="48"/>
        <Button Grid.Row="7" Grid.Column="2" Content="&#x232B;"
                Click="BackspaceButton_Click" Margin="2"
                Background="LightCoral" FontSize="48"/>
        <Button Grid.Row="7" Grid.Column="3" Content="="
                Click="EqualsButton_Click" Margin="2" FontSize="48"/>
    </Grid>
</Window>
