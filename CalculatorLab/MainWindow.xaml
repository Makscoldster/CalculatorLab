<Window x:Class="CalculatorLab.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор Lab2" Height="800" Width="600" MinHeight="500" MinWidth="30">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Дисплей -->
            <RowDefinition Height="*"/>
            <!-- Ряд 1 -->
            <RowDefinition Height="*"/>
            <!-- Ряд 2 -->
            <RowDefinition Height="*"/>
            <!-- Ряд 3 -->
            <RowDefinition Height="*"/>
            <!-- Ряд 4 -->
            <RowDefinition Height="*"/>
            <!-- Ряд 5 (0, =, CE, C) -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Дисплей -->
        <TextBox x:Name="Display" Grid.Row="0" Grid.ColumnSpan="4" 
                 FontSize="48" FontWeight="Bold" TextAlignment="Right" 
                 Text="0" IsReadOnly="True" VerticalContentAlignment="Center"
                 Margin="0,0,5,10"/>

        <!-- Кнопки цифр і операцій -->
        <Button x:Name="btn7" Grid.Row="1" Grid.Column="0" Content="7" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btn8" Grid.Row="1" Grid.Column="1" Content="8" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btn9" Grid.Row="1" Grid.Column="2" Content="9" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btnDivide" Grid.Row="1" Grid.Column="3" Content="÷" Click="OperatorButton_Click" Margin="2" FontSize="48"/>

        <Button x:Name="btn5" Grid.Row="2" Grid.Column="1" Content="5" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btn6" Grid.Row="2" Grid.Column="2" Content="6" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btn4" Grid.Row="2" Grid.Column="0" Content="4" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btnMultiply" Grid.Row="2" Grid.Column="3" Content="×" Click="OperatorButton_Click" Margin="2" FontSize="48"/>

        <Button x:Name="btn1" Grid.Row="3" Grid.Column="0" Content="1" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btn2" Grid.Row="3" Grid.Column="1" Content="2" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btn3" Grid.Row="3" Grid.Column="2" Content="3" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btnSubtract" Grid.Row="3" Grid.Column="3" Content="−" Click="OperatorButton_Click" Margin="2" FontSize="48"/>

        <Button x:Name="btn0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Content="0" Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btnDot" Grid.Row="4" Grid.Column="2" Content="." Click="NumberButton_Click" Margin="2" FontSize="48"/>
        <Button x:Name="btnEquals" Grid.Row="4" Grid.Column="3" Content="=" Click="EqualsButton_Click" Margin="2" FontSize="48"/>

        <Button x:Name="btnCE" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Content="CE" Click="CEButton_Click" Margin="2" Background="LightCoral" FontSize="48"/>
        <Button x:Name="btnC" Grid.Row="5" Grid.Column="2" Content="C" Click="CButton_Click" Margin="2" Background="LightCoral" FontSize="48"/>
        <Button x:Name="btnAdd" Grid.Row="5" Grid.Column="3" Content="+" Click="OperatorButton_Click" Margin="2" FontSize="48"/>
    </Grid>
</Window>
